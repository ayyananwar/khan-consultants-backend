DATABASE_URL="postgresql://postgres:password@localhost:5432/khan_backend?schema=public"
PORT=4000
NODE_ENV=production
TZ=Asia/Kolkata

# Comma-separated allowed frontend origins
CORS_ORIGIN=https://khanconsultants.in,https://www.khanconsultants.in,https://*.netlify.app

# Admin authentication
ADMIN_PASSWORD=change-this-to-a-strong-password

# Optional first-run defaults only (after first admin update, DB-backed settings are used)
# BOOKING_FEE=199
# APPOINTMENT_WINDOW=9:20 AM - 9:50 AM

# Razorpay (required for createOrder / verifyPaymentAndSave)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Resend email (for birth booking confirmation after payment success)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Khan Consultants <onboarding@resend.dev>
# Optional reply-to for customer replies
# EMAIL_REPLY_TO=khanconsultants2025@gmail.com
# Optional retry tuning
# BOOKING_EMAIL_MAX_RETRIES=3
# BOOKING_EMAIL_RETRY_DELAY_MS=900

# Optional rate limits
# API_RATE_LIMIT_WINDOW_MS=900000
# API_RATE_LIMIT_MAX=300
# ADMIN_RATE_LIMIT_WINDOW_MS=900000
# ADMIN_RATE_LIMIT_MAX=200
